import torch

def reparametrize(mu, logvar):
    """
    实现重参数化技巧 z = mu + sigma * epsilon
    """
    z = None
    ###############################################################################
    # TODO: Reparametrize by initializing epsilon as a normal distribution and    #
    # scaling by posterior mu and sigma to estimate z                             #
    ###############################################################################
    
    # 1. 从 logvar 计算标准差 std (sigma)
    # sigma = sqrt(exp(logvar)) = exp(0.5 * logvar)
    std = torch.exp(0.5 * logvar)
    
    # 2. 采样 epsilon (从标准正态分布 N(0, 1) 中采样)
    # torch.randn_like 会生成一个与 std 形状相同且符合标准正态分布的张量
    eps = torch.randn_like(std)
    
    # 3. 计算 z = mu + sigma * epsilon
    z = mu + eps * std
    
    ###############################################################################
    #                               END OF YOUR CODE                              #
    ###############################################################################
    return z

