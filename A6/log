import torch

def sample_noise(batch_size, noise_dim, dtype=torch.float, device='cpu'):
    """
    生成范围在 [-1, 1] 之间的均匀分布随机噪声。
    
    Inputs:
    - batch_size: 整数，代表 minibatch 的大小
    - noise_dim: 整数，代表噪声向量的维度
    
    Returns:
    - 一个形状为 [batch_size, noise_dim] 的张量
    """
    # torch.rand 生成 [0, 1)
    # 乘以 2 变成 [0, 2)
    # 减去 1 变成 [-1, 1)
    noise = torch.rand(batch_size, noise_dim, dtype=dtype, device=device) * 2 - 1
    
    return noise

