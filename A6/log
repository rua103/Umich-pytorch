import torch.nn.functional as F

def loss_function(x_hat, x, mu, logvar):
    """
    计算 VAE 损失：BCE + KL
    
    Inputs:
    - x_hat: 重建后的图像 (N, 1, H, W)
    - x: 原始图像 (N, 1, H, W)
    - mu: 隐空间的均值 (N, Z)
    - logvar: 隐空间的对数方差 (N, Z)
    """
    # 1. 计算重建损失 (Reconstruction Loss)
    # 使用 binary_cross_entropy，计算所有像素点的误差总和
    # 注意：需要把 reduction 设为 'sum'
    reconstruction_loss = F.binary_cross_entropy(x_hat, x, reduction='sum')

    # 2. 计算 KL 散度 (KL Divergence)
    # 使用作业给出的公式：-0.5 * sum(1 + logvar - mu^2 - exp(logvar))
    # 我们对 Batch 内的所有维度进行求和
    kl_divergence = -0.5 * torch.sum(1 + logvar - mu.pow(2) - logvar.exp())

    # 3. 计算总损失并对 Batch 求平均
    # N 是 Batch Size
    N = x.shape[0]
    loss = (reconstruction_loss + kl_divergence) / N
    
    return loss

