import torch
import torch.nn as nn

class FlexibleNet(nn.Module):
    def __init__(self):
        super(FlexibleNet, self).__init__()
        # 将网络层存入 ModuleList，此时它们还没有任何联系
        self.layers = nn.ModuleList([
            nn.Linear(10, 10),
            nn.Linear(10, 10),
            nn.Linear(10, 5)
        ])

    def forward(self, x):
        # 必须手动定义前向传播逻辑
        for i, layer in enumerate(self.layers):
            if i == 2:
                # 可以在这里做一些复杂的操作，比如加入跳跃连接或分支
                x = layer(x) + some_other_tensor # 假设这里有其他的张量
            else:
                x = torch.relu(layer(x))
        return x

